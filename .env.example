# Copy to .env and adjust. The CLI reads these on startup; command flags win.

# inference backend: mock | ollama | llamacpp | mlx
SENTINEL_PROVIDER=ollama

# OpenAI-compatible endpoint (leave blank to use the provider default)
# ollama:   http://localhost:11434/v1
# llamacpp: http://localhost:8080/v1
SENTINEL_BASE_URL=

# model name/tag — point this at your LFM 2.5 build
SENTINEL_MODEL=lfm2.5

# optional bearer token for the endpoint (usually empty for local servers)
SENTINEL_API_KEY=

# autonomy level for the MCP server: plan | readonly | auto | full
# plan=never run; readonly=run reads/defer writes; auto=run reads+writes; full=run everything
SENTINEL_MODE=readonly
