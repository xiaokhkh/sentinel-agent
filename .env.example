# Copy to .env and adjust. The CLI reads these on startup; command flags win.

# inference backend: mock | ollama | llamacpp | mlx  (default: llamacpp)
SENTINEL_PROVIDER=llamacpp

# OpenAI-compatible endpoint (leave blank to use the provider default)
# llamacpp: http://localhost:8080/v1   (guard auto-starts llama-server here)
# ollama:   http://localhost:11434/v1
SENTINEL_BASE_URL=

# model — for llamacpp this is passed to `llama-server -hf` (HF repo id);
# for ollama/mlx it is the model tag.
SENTINEL_MODEL=LiquidAI/LFM2.5-1.2B-Instruct-GGUF

# optional bearer token for the endpoint (usually empty for local servers)
SENTINEL_API_KEY=

# autonomy level for the MCP server: readonly | auto | full
# readonly=run reads/defer writes; auto=run reads+writes; full=run everything (dangerous)
SENTINEL_MODE=readonly
